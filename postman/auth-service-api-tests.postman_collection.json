				},
				{
					"name": "04. Validate Token",
					"request": {
						"method": "POST",
						"header": [],
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/auth/validate"
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"  pm.response.to.have.status(200);",
									"});",
									"var body = pm.response.json();",
									"pm.test('Token is valid', function () {",
									"  pm.expect(body.valid).to.eql(true);",
									"});",
									"pm.test('Validated email matches', function () {",
									"  pm.expect(body.email).to.eql(pm.collectionVariables.get('testEmail'));",
									"});"
								]
							}
						}
					]
				},
