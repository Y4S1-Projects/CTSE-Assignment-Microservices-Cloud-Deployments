	"item": [
		{
			"name": "Core Auth Flow",
			"item": [
				{
					"name": "01. Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/auth/health"
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"  pm.response.to.have.status(200);",
									"});",
									"var body = pm.response.json();",
									"pm.test('Service is UP', function () {",
									"  pm.expect(body.status).to.eql('UP');",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "02. Register User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{ \"email\": \"{{testEmail}}\", \"password\": \"{{currentPassword}}\", \"fullName\": \"Postman Test User\" }",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register"
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200 or 201', function () {",
									"  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"var body = pm.response.json();",
									"var accessToken = body.accessToken || body.token;",
									"pm.test('Tokens are returned', function () {",
									"  pm.expect(accessToken, 'access token').to.be.ok;",
									"  pm.expect(body.refreshToken, 'refresh token').to.be.ok;",
									"});",
									"pm.collectionVariables.set('accessToken', accessToken);",
									"pm.collectionVariables.set('refreshToken', body.refreshToken);"
								]
							}
						}
					]
				},
				{
					"name": "03. Login User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{ \"email\": \"{{testEmail}}\", \"password\": \"{{currentPassword}}\" }",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login"
