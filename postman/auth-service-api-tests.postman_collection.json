{
	"info": {
		"_postman_id": "d2f5a6a2-9f0f-4d77-9fb1-0b73d1c5af1a",
		"name": "Auth Service API Surface Tests",
		"description": "Import this collection and set baseUrl to http://localhost:8081 for direct auth-service testing or http://localhost:8080 for gateway testing. The collection seeds unique test data from the Health Check request and runs the full auth lifecycle plus admin CRUD.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"if (pm.info.requestName === '01. Health Check') {",
					"  var seed = Date.now().toString(36) + Math.random().toString(36).slice(2, 8);",
					"  pm.collectionVariables.set('testEmail', 'postman.' + seed + '@example.com');",
					"  pm.collectionVariables.set('adminTestEmail', 'admin.postman.' + seed + '@example.com');",
					"  pm.collectionVariables.set('currentPassword', pm.collectionVariables.get('testPassword'));",
					"  pm.collectionVariables.set('accessToken', '');",
					"  pm.collectionVariables.set('refreshToken', '');",
					"  pm.collectionVariables.set('resetToken', '');",
					"  pm.collectionVariables.set('adminToken', '');",
					"  pm.collectionVariables.set('createdUserId', '');",
					"}"
				]
			}
		}
	],
