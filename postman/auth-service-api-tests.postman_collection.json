							"mode": "raw",
							"raw": "{ \"fullName\": \"Postman Test User Updated\", \"phone\": \"0712345678\", \"addresses\": [{ \"label\": \"Home\", \"street\": \"1 Main St\", \"city\": \"Colombo\", \"state\": \"WP\", \"postalCode\": \"10100\", \"country\": \"Sri Lanka\", \"isDefault\": true }, { \"label\": \"Work\", \"street\": \"2 Main St\", \"city\": \"Kandy\", \"state\": \"CP\", \"postalCode\": \"20200\", \"country\": \"Sri Lanka\", \"isDefault\": false }, { \"label\": \"Other\", \"street\": \"3 Main St\", \"city\": \"Galle\", \"state\": \"SP\", \"postalCode\": \"30300\", \"country\": \"Sri Lanka\", \"isDefault\": false }] }",
							"options": {
