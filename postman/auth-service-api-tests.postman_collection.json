									"pm.test('Status code is 200', function () {",
									"  pm.response.to.have.status(200);",
									"});",
									"var body = pm.response.json();",
									"var accessToken = body.accessToken || body.token;",
									"pm.test('Tokens are returned', function () {",
									"  pm.expect(accessToken, 'access token').to.be.ok;",
									"  pm.expect(body.refreshToken, 'refresh token').to.be.ok;",
									"});",
									"pm.collectionVariables.set('accessToken', accessToken);",
									"pm.collectionVariables.set('refreshToken', body.refreshToken);"
								]
							}
						}
