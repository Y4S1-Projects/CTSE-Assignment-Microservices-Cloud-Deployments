# Auth Service local environment template
# Copy to `.env` and replace values.

# Required security
JWT_SECRET=replace-with-a-strong-random-secret
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRY_DAYS=7

# Required database (PostgreSQL / Neon)
DATABASE_URL=jdbc:postgresql://ep-bitter-heart-aogzv7s0.c-2.ap-southeast-1.aws.neon.tech:5432/neondb?sslmode=require
DATABASE_USER=<neon-db-user>
DATABASE_PASSWORD=<neon-db-password>

# Bootstrap users (optional)
ADMIN_PASSWORD=replace-admin-password
CUSTOMER_PASSWORD=replace-customer-password
